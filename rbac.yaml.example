# Declarative RBAC for Hubble.
# Copy to rbac.yaml or point RBAC_PATH at your file.
# rbac.yaml is git-ignored (like .env); only this example is tracked.
# Changes take effect without restart (polling interval applies, or SIGHUP).
#
# Roles are resolved and exposed via GET /api/me, and permissions
# (query.write / query.killAny / queries.viewAll / datasources allowlist) are
# enforced.

roles:
  admin:
    # query.write: 書き込み SQL の実行を許可
    # ai.use: SQL Workbench の AI アシスタント機能を利用可能にする
    # query.killAny: Operations ビューから任意ユーザーのクエリを kill
    # queries.viewAll: Operations ビューで全ユーザーの実行中クエリを閲覧
    # audit.view: 管理 API から監査ログを検索
    permissions: [query.write, ai.use, query.killAny, queries.viewAll, audit.view]
    # datasources: ロールが利用できる datasource id の allowlist(必須)
    # - ['*']: 明示的に全許可
    # - [trino-prod, mysql-analytics]: 列挙 id のみ許可
    # - []: いずれの datasource も許可しない
    datasources: ['*']
  operator:
    # operator も同様に運用ビューと kill を使える例
    permissions: [query.write, query.killAny, queries.viewAll]
    guard:
      maxScanBytes: 500000000000
    # Trino のみ許可する例(MySQL/PostgreSQL の共有 credential 露出を抑える)
    datasources: [trino-prod]
  member:
    permissions: []
    guard:
      maxScanBytes: 50000000000
      onUnknown: block
    datasources: [trino-prod]

assignments:
  # priority は大きい値から評価される。未指定は 0、同値は記述順になる
  - email: alice@example.com
    priority: 100
    role: admin
  - user: local-dev
    role: admin
  - group: admins@example.com
    role: operator
  - emailDomain: example.com
    role: member

defaultRole: member
