# Hubble SQL Workbench — environment template.
#
# Copy to `.env` and adjust. `.env` is git-ignored (this template is tracked).
# The authoritative list of variables and defaults is packages/server/src/config.ts,
# documented in docs/operations.md §4. Unset (or empty) values fall back to the
# defaults shown below.
#
# Loading the file for local dev (server reads process.env):
#   set -a && source .env && set +a && pnpm dev
# or pass it to tsx directly:
#   pnpm --filter @hubble/server exec tsx --env-file=../../.env src/index.ts
#
# docker compose reads `.env` automatically (see docker-compose.yml env_file).

# --- HTTP / persistence ---
PORT=8080
# API request body 全体の最大 byte 数。超過時は HTTP 413。既定 2097152。
# HTTP_MAX_BODY_BYTES=2097152
# 受付停止から強制 close へ移るまでの期限（ミリ秒）。既定 60000。
# SHUTDOWN_TIMEOUT_MS=60000
# PostgreSQL connection string (1st/production-recommended backend). When set
# (postgres:// or postgresql://), the persistence backend is PostgreSQL and
# DATABASE_URL takes precedence over DB_PATH. See docs/operations.md §9.
DATABASE_URL=postgres://hubble:hubble@localhost:5432/hubble
# SQLite file path (non-production fallback; used only when DATABASE_URL is
# unset). Use :memory: for a volatile DB (tests only).
# DB_PATH=./data/hubble.db
# Built web app dir for single-process static serving (unset = API only).
# STATIC_DIR=./packages/web/dist

# --- Data sources (declarative YAML, required) ---
# Path to datasources.yaml. When unset, ./datasources.yaml is used if present.
# This file is required: startup fails if neither path resolves to a file.
# DATASOURCES_PATH=./datasources.yaml
# Poll datasources.yaml/rbac.yaml mtime for hot reload (seconds). 0 = SIGHUP only. Default 30.
# CONFIG_RELOAD_INTERVAL_SECONDS=30
# Docker Compose demo (docker-compose.demo.yml) passwordEnv targets:
# DEMO_MYSQL_PASSWORD=hubble-demo
# DEMO_POSTGRES_PASSWORD=hubble-demo
# Example passwordEnv target for a trino datasource entry in datasources.yaml
# (name is arbitrary; must match the entry's passwordEnv value):
# TRINO_PASSWORD=

# --- RBAC (declarative YAML) ---
# Path to rbac.yaml. When unset, ./rbac.yaml is used if present;
# otherwise every principal gets the built-in unrestricted role (legacy behavior).
# RBAC_PATH=./rbac.yaml

# --- Trino impersonation user ---
# X-Trino-User sent for all Trino datasources. `none` mode uses this value as
# the principal directly; `proxy` mode uses the resolved SSO principal instead
# (this value is then only the owner-backfill seed). Connection info (baseUrl,
# Basic-auth credentials, X-Trino-Source tags) lives in datasources.yaml, not here.
TRINO_USER=admin

# --- Defaults for new notebooks ---
DEFAULT_CATALOG=tpch
DEFAULT_SCHEMA=tiny
# DEFAULT_LIMIT=5000

# --- Query / metadata tuning (see docs/operations.md §10) ---
# QUERY_MAX_ROWS=100000
# QUERY_CONCURRENCY=5
# 実行枠を待てるクエリの全体上限。既定 100。
# QUERY_MAX_QUEUED=100
# 同一 principal が実行枠を待てるクエリの上限。既定 20。
# QUERY_MAX_QUEUED_PER_PRINCIPAL=20
# 終端済みを含めて registry が保持するクエリの上限。既定 10000。
# QUERY_MAX_TRACKED=10000
# QUERY_TTL_MINUTES=30
# QUERY_OVERFLOW_MODE=truncate
# METADATA_TTL_SECONDS=300

# --- Query result persistence (see docs/operations.md §9.4) ---
# RESULT_STORE=none                  # none | s3
# RESULT_STORE_TTL_DAYS=7
# RESULT_STORE_S3_BUCKET=
# RESULT_STORE_S3_PREFIX=hubble-results/
# RESULT_STORE_S3_REGION=
# RESULT_STORE_S3_ENDPOINT=          # optional; when set, S3 client uses path-style requests

# --- Query result export destinations (see docs/operations.md §9.5) ---
# Optional destinations for the Export menu in the result pane.
# EXPORT_S3_BUCKET=
# EXPORT_S3_PREFIX=hubble-exports/
# EXPORT_S3_REGION=
# EXPORT_S3_ENDPOINT=               # optional; when set, S3 client uses path-style requests
# EXPORT_SHEETS_CREDENTIALS_FILE=   # service-account JSON file for Google Sheets and Drive APIs

# --- Query Guard (see docs/operations.md §8.6) ---
# Estimate scan cost via EXPLAIN before execution and warn/block over-limit queries.
# QUERY_GUARD_MODE=warn             # off | warn (default) | enforce
# QUERY_GUARD_MAX_SCAN_BYTES=0      # 0 = unlimited
# QUERY_GUARD_MAX_SCAN_ROWS=0       # 0 = unlimited
# QUERY_GUARD_ON_UNKNOWN=warn       # allow | warn (default) | block
# QUERY_GUARD_ESTIMATE_TIMEOUT_MS=3000
# QUERY_GUARD_CACHE_TTL_SECONDS=30
# QUERY_GUARD_BYTES_PER_SECOND=0    # 0 = no duration hint; >0 shows estimated duration in UI

# --- Scheduler (see docs/operations.md §12) ---
# Run saved SQL on a cron schedule. The tick loop scans for due schedules every
# SCHEDULER_TICK_SECONDS seconds using the server's local timezone.
# SCHEDULER_ENABLED=true          # false = stop tick loop (API stays live)
# SCHEDULER_TICK_SECONDS=15       # scan interval in seconds
# SCHEDULER_MAX_CONCURRENT=2      # max schedules running concurrently
# 日本語: 現在は schedule、workflow step、alert の statement 共有実行上限として使う。
# SCHEDULER_RUNS_RETENTION=50     # per-schedule run-history row cap (older rows pruned)
# --- 永続テーブルの保持期限 ---
# ALERT_DELIVERY_RETENTION_DAYS=30  # 0 disables automatic pruning
# QUERY_HISTORY_RETENTION_DAYS=90   # 0 disables automatic pruning
# AUDIT_LOG_RETENTION_DAYS=365      # 0 disables automatic pruning
# DATA_RETENTION_BATCH_SIZE=500
# X-Trino-Source for scheduled runs is set per-datasource (scheduledSource in
# datasources.yaml, default hubble-scheduled), not via an env var here.

# --- GitHub token暗号鍵のローテーション（docs/operations.md §13） ---
# GITHUB_TOKEN_ENCRYPTION_KEY=<base64-encoded 32-byte active master key>
# GITHUB_TOKEN_ENCRYPTION_KEY_ID=default
# 旧key IDとbase64化した旧master keyをJSON objectで指定する。
# 保存済みtokenの遅延再暗号化が終わるまで旧鍵を残す。
# GITHUB_TOKEN_ENCRYPTION_KEYRING={"previous":"<base64-encoded 32-byte key>"}

# --- Schedule failure notifications (see docs/operations.md §12) ---
# Slack incoming webhook URL. Required only when schedules select Slack.
# NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
# SMTP settings. Required only when schedules select email.
# NOTIFY_SMTP_HOST=smtp.example.com
# NOTIFY_SMTP_PORT=587              # 465 = implicit TLS; others use STARTTLS when available
# NOTIFY_SMTP_USER=hubble
# NOTIFY_SMTP_PASSWORD_ENV=SMTP_PASSWORD
# SMTP_PASSWORD=
# NOTIFY_SMTP_FROM=hubble@example.com

# --- Auth (see docs/operations.md §7) ---
# AUTH_MODE=none
# AUTH_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128
# AUTH_SSO_HEADER_USER=x-forwarded-user
# AUTH_SSO_HEADER_EMAIL=x-forwarded-email
# AUTH_SSO_HEADER_GROUPS=x-forwarded-groups
# AUTH_USER_MAPPING=email-localpart
