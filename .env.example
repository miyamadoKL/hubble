# Hubble SQL Workbench — environment template.
#
# Copy to `.env` and adjust. `.env` is git-ignored (this template is tracked).
# The authoritative list of variables and defaults is packages/server/src/config.ts,
# documented in docs/operations.md §4. Unset (or empty) values fall back to the
# defaults shown below.
#
# Loading the file for local dev (server reads process.env):
#   set -a && source .env && set +a && pnpm dev
# or pass it to tsx directly:
#   pnpm --filter @hubble/server exec tsx --env-file=../../.env src/index.ts
#
# docker compose reads `.env` automatically (see docker-compose.yml env_file).

# --- HTTP / persistence ---
PORT=8080
# SQLite file path. Use :memory: for a volatile DB (tests only).
DB_PATH=./data/hubble.db
# PostgreSQL connection string. When set (postgres:// or postgresql://), the
# persistence backend is PostgreSQL and DATABASE_URL takes precedence over
# DB_PATH. Unset (default) = SQLite via DB_PATH. See docs/operations.md §9.4.
# DATABASE_URL=postgres://hubble:hubble@localhost:5432/hubble
# Built web app dir for single-process static serving (unset = API only).
# STATIC_DIR=./packages/web/dist

# --- Trino connection ---
# Coordinator base URL. In docker compose the demo service is http://trino:8080.
TRINO_BASE_URL=http://127.0.0.1:30080
# X-Trino-User (execution user in `none` mode / metadata user in `proxy` mode).
TRINO_USER=admin
# Basic-auth credentials for the technical account.
TRINO_USERNAME=admin
TRINO_PASSWORD=
# X-Trino-Source values (used for resource-group separation in Trino).
# TRINO_SOURCE=hubble
# TRINO_METADATA_SOURCE=hubble-metadata

# --- Defaults for new notebooks ---
DEFAULT_CATALOG=tpch
DEFAULT_SCHEMA=tiny
# DEFAULT_LIMIT=5000

# --- Query / metadata tuning (see docs/operations.md §10) ---
# QUERY_MAX_ROWS=100000
# QUERY_CONCURRENCY=5
# QUERY_TTL_MINUTES=30
# QUERY_OVERFLOW_MODE=truncate
# METADATA_TTL_SECONDS=300

# --- Query Guard (see docs/operations.md §8.6) ---
# Estimate scan cost via EXPLAIN before execution and warn/block over-limit queries.
# QUERY_GUARD_MODE=warn             # off | warn (default) | enforce
# QUERY_GUARD_MAX_SCAN_BYTES=0      # 0 = unlimited
# QUERY_GUARD_MAX_SCAN_ROWS=0       # 0 = unlimited
# QUERY_GUARD_ON_UNKNOWN=warn       # allow | warn (default) | block
# QUERY_GUARD_ESTIMATE_TIMEOUT_MS=3000
# QUERY_GUARD_CACHE_TTL_SECONDS=30
# QUERY_GUARD_BYTES_PER_SECOND=0    # 0 = no duration hint; >0 shows estimated duration in UI

# --- Scheduler (see docs/operations.md §12) ---
# Run saved SQL on a cron schedule. The tick loop scans for due schedules every
# SCHEDULER_TICK_SECONDS seconds using the server's local timezone.
# SCHEDULER_ENABLED=true          # false = stop tick loop (API stays live)
# SCHEDULER_TICK_SECONDS=15       # scan interval in seconds
# SCHEDULER_MAX_CONCURRENT=2      # max schedules running concurrently
# SCHEDULER_RUNS_RETENTION=50     # per-schedule run-history row cap (older rows pruned)
# TRINO_SCHEDULED_SOURCE=hubble-scheduled  # X-Trino-Source for scheduled runs

# --- Auth (see docs/operations.md §7) ---
# AUTH_MODE=none
# AUTH_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128
# AUTH_SSO_HEADER_USER=x-forwarded-user
# AUTH_SSO_HEADER_EMAIL=x-forwarded-email
# AUTH_USER_MAPPING=email-localpart
