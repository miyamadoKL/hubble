# Declarative datasource definitions for Hubble (Grafana provisioning style).
# Copy to datasources.yaml or point DATASOURCES_PATH at your file.
# datasources.yaml is git-ignored (like .env); only this example is tracked.
# Secrets are referenced via passwordEnv or passwordFile, not stored in YAML.
# This file is required (server refuses to start without it) and supports hot
# reload: changes take effect without a restart, via mtime polling
# (CONFIG_RELOAD_INTERVAL_SECONDS, default 30s) or SIGHUP.

datasources:
  - id: trino-prod
    type: trino
    displayName: Production Trino
    username: admin
    passwordEnv: TRINO_PASSWORD
    baseUrl: http://trino:8080
    # X-Trino-Source tags, one per use case (resource-group separation in
    # Trino). All three are optional; shown defaults apply when omitted.
    source: hubble                     # user queries (default: hubble)
    metadataSource: hubble-metadata    # catalog/schema/table metadata fetches (default: hubble-metadata)
    scheduledSource: hubble-scheduled  # query scheduler runs (default: hubble-scheduled)

  - id: mysql-analytics
    type: mysql
    displayName: Analytics MySQL
    username: hubble
    passwordFile: /var/run/secrets/mysql-password
    host: mysql.internal
    port: 3306
    database: analytics
    # 省略時 readOnly: true。SET SESSION TRANSACTION READ ONLY を発行するガードレール。
    # 本気のアクセス制御は DB 側の権限で行う。
    readOnly: true
    # TLS を有効化する場合は tls: true。CA 証明書は tlsCaFile で指定可能(tls: true 必須)。
    # tls: true
    # tlsCaFile: /var/run/secrets/mysql-ca.pem
    # maxConnections: 5

  - id: pg-warehouse
    type: postgresql
    displayName: Warehouse PostgreSQL
    username: hubble
    passwordEnv: PG_PASSWORD
    host: postgres.internal
    database: warehouse
    readOnly: true
    # tls: true
    # tlsCaFile: /var/run/secrets/pg-ca.pem
    # maxConnections: 5
