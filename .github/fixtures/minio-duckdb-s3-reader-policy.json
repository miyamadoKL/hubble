{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": "arn:aws:s3:::hubble-duckdb-s3-gate"
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::hubble-duckdb-s3-gate",
      "Condition": { "StringLike": { "s3:prefix": ["gate/*"] } }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::hubble-duckdb-s3-gate/gate/*"
    }
  ]
}
